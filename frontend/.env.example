# ─────────────────────────────────────────────────────────────
# SprintFlow Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# true  = local dummy data, no backend needed (dev only)
# false = calls real Spring Boot backend (REQUIRED for production)
VITE_USE_MOCK=false

# Development: leave as-is (Vite proxy forwards /api → localhost:8080)
# Production:  set to your EC2 IP or domain
# e.g. VITE_API_BASE_URL=http://YOUR_EC2_IP:8080/api
VITE_API_BASE_URL=http://localhost:8080/api

# Optional — defaults to same host as API with /ws path
# Production: VITE_WS_URL=http://YOUR_EC2_IP:8080
# VITE_WS_URL=http://localhost:8080
