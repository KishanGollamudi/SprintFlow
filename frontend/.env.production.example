# ─────────────────────────────────────────────────────────────
# SprintFlow Frontend — Production Environment Variables
# Copy this file to .env.production and fill in real values
# before running: npm run build
# ─────────────────────────────────────────────────────────────

# Full URL to the backend API including /api suffix
# Example: https://sprintflow-backend.us-east-1.elasticbeanstalk.com/api
#      or: https://api.yourdomain.com/api
VITE_API_BASE_URL=https://YOUR_BACKEND_URL/api

# WebSocket URL — points directly to backend (bypasses CloudFront)
# Must be the ALB or EB URL, NOT the CloudFront URL
# Example: https://sprintflow-backend.us-east-1.elasticbeanstalk.com
VITE_WS_URL=https://YOUR_BACKEND_URL

# Set to false in production
VITE_USE_MOCK=false
